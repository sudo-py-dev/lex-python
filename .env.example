# Telegram API Credentials (get from my.telegram.org)
API_ID=12345
API_HASH=your_api_hash

# Bot Token (get from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://bot:bot_password@localhost:5432/botdb?schema=public"

# Bot Owner Configuration
OWNER_ID=12345678

# Logging and Performance
LOG_LEVEL="INFO"
ENABLE_VIDEO_WATERMARK=true
VIDEO_WATERMARK_MAX_SIZE_MB=50

# AI Chat Protection (Groq Models)
AI_GUARD_MODEL="llama-3.1-8b-instant"
AI_GUARD_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
AI_GUARD_MAX_IMAGE_SIZE_MB=10

